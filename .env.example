# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# PostgreSQL
POSTGRES_USER=osint
POSTGRES_PASSWORD=osint_dev
POSTGRES_DB=osint_dev

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Vault (optional — set VAULT_ENABLED=true to use)
VAULT_ENABLED=false
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-only-token
VAULT_MOUNT_POINT=secret
VAULT_PROXY_PATH=osint/proxy
VAULT_TIMEOUT=5

# Proxy credentials (env var fallback when Vault is disabled)
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# Frontend production reverse proxy target
FRONTEND_BACKEND_UPSTREAM=host.docker.internal:8000

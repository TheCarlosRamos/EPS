{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(ruff check *)",
      "Bash(ruff format *)",
      "Bash(bandit *)",
      "Bash(safety *)",
      "Bash(python -m pytest *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh repo *)",
      "Bash(docker compose *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)"
    ],
    "deny": [
      "Bash(git push --force origin main)",
      "Bash(git push -f origin main)",
      "Bash(rm -rf /)*"
    ]
  },
  "env": {
    "RUFF_CONFIG": "documentation/secops/pyproject.toml",
    "PYTHONDONTWRITEBYTECODE": "1"
  }
}
